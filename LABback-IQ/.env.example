# ─────────────────────────────────────────────────────────────────────────────
# Circuit IQ — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=change-me-to-a-random-secret-string
FLASK_DEBUG=true

# Gemini AI (Phase 3 — PhysicsBot)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Supabase (Phase 2 — Auth & Database)
# Get these from your Supabase project settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend email (Phase 6 — Contact form notifications)
# Free tier: 100 emails/day — https://resend.com
RESEND_API_KEY=
CONTACT_TO_EMAIL=team@circuitiq.dev

# Server port (default 5000)
PORT=5000
